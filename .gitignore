# OS
.DS_Store
Thumbs.db

# Python (for the future OKF validator / scripts)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.python-version

# Coverage artifacts(本地生成,CI 单独上传 artifact)
.coverage
coverage.xml

# Node (if any tooling is added later)
node_modules/

# OKF generated artifacts
# viz.html is a generated single-file viewer; keep bundles, ignore generated viz
wiki/**/viz.html

# Editor / IDE
.idea/
.vscode/
*.swp

# superpowers SDD scratch (progress ledger, scripts)
.superpowers/

# Generated release packages
dist/
build/

# Per-test ephemeral scratch (e.g. fresh venv for entrypoint tests).
.pytest-tmp/

# Derived cache dirs (sqlite3 + FTS5 index, model cache) — never in git,
# at any depth.
**/.mneme/
.mneme/
*.mneme/
